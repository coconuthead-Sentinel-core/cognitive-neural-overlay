# Copy to .env and fill in for production.
# All variables are optional — sensible defaults apply when absent.

# --- Auth + rate limit ---
# When CNO_API_KEY is set, all routes except /healthz, /, /docs, /redoc,
# /openapi.json, and /ui* require X-API-Key: <value>.
# CNO_API_KEY=replace-with-a-real-secret

# CSV of allowed CORS origins. Defaults to "*" (open). Restrict in prod.
# CNO_ALLOWED_ORIGINS=https://your-frontend.example.com,https://admin.example.com

# Sliding 60s window per API key (or per IP if no key). Set to 0 to disable.
# CNO_RATE_LIMIT_PER_MINUTE=120

# --- Persistence ---
# Path to the SQLite audit DB. The Docker image defaults to /data/cno_audit.db.
# CNO_DB_PATH=/data/cno_audit.db

# --- AMC bridge (Canon #7) ---
# null | jsonl | http   (default: null)
# CNO_AMC_SINK=jsonl
# CNO_AMC_JSONL_PATH=/data/cno_anchors.jsonl
# CNO_AMC_URL=https://amc.internal
# CNO_AMC_API_KEY=

# --- Runtime ---
# Override the host-side port the container exposes (compose only).
# HOST_PORT=8000

# Number of uvicorn workers. 1 is fine for low traffic; 2-4 for prod.
# UVICORN_WORKERS=2
